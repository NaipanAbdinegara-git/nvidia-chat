# ============================================================
# Environment Variables — copy this file into .env.local
# Development only, choose vercel for deploy
# ============================================================

# Get it on: https://build.nvidia.com → API Keys
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx

# Firebase — Get it on Firebase Console → Project Settings → General → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy-xxxxxxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
